{
  "name": "pacsviewer",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "predev": "lsof -ti:3000,5173 | xargs kill -9 2>/dev/null; true",
    "dev": "bun run --filter '*' dev",
    "dev:server": "bun run --filter @pacsviewer/server dev",
    "dev:web": "bun run --filter @pacsviewer/web dev",
    "build": "bun run --filter '*' build",
    "build:server": "bun run --filter @pacsviewer/server build",
    "build:web": "bun run --filter @pacsviewer/web build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "db:generate": "bun run --filter @pacsviewer/server db:generate",
    "db:migrate": "bun run --filter @pacsviewer/server db:migrate",
    "db:push": "bun run --filter @pacsviewer/server db:push",
    "db:seed": "bun run --filter @pacsviewer/server db:seed"
  },
  "devDependencies": {
    "@radix-ui/react-label": "^2.1.11",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.3.0"
  }
}
