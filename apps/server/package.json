{
  "name": "@pacsviewer/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:seed-hrf": "bun run scripts/seed-hrf.ts",
    "db:seed-clean": "bun run scripts/clean-synthetic.ts",
    "db:cleanup": "bun run scripts/cleanup-full.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@pacsviewer/image-processing": "workspace:*",
    "better-auth": "^0.2.0",
    "dcmjs": "^0.52.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.0.0",
    "parse-multipart-data": "^1.5.0",
    "sharp": "^0.33.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/uuid": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.3.0"
  }
}
